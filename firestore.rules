rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // -------------------------------------------------------------------------
    // VALIDATORS
    // -------------------------------------------------------------------------
    function isValidRecommendation(data) {
      return data.keys().hasAll(['authorId', 'title', 'comment'])
        && data.authorId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.comment is string && data.comment.size() <= 2000;
    }

    function isNotAuthor(recId) {
      // Use the parent path variable if available, or fetch
      let rec = get(/databases/$(database)/documents/recommendations/$(recId));
      return rec != null && rec.data.authorId != request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        incoming().diff(existing()).affectedKeys().hasOnly(['avgRecommendationRating', 'totalRecommendationRatingSum', 'totalRecommendationRatingCount', 'recsCount', 'watchedCount', 'currentlyWatching'])
      );
      allow create: if isOwner(userId);
    }

    match /usernames/{name} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /recommendations/{recId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRecommendation(incoming());
      allow update: if isSignedIn() && (isOwner(existing().authorId) || incoming().diff(existing()).affectedKeys().hasOnly(['averageRating', 'ratingCount']));
      allow delete: if isSignedIn() && isOwner(existing().authorId);

      match /ratings/{userId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && userId == request.auth.uid 
          && incoming().rating >= 1 && incoming().rating <= 5;
        allow delete: if isSignedIn() && userId == request.auth.uid;
      }
      
      match /actions/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && userId == request.auth.uid;
      }
    }

    match /userActions/{actionId} {
      allow read: if isSignedIn();
      // Allow writing if the action belongs to the user
      allow write: if isSignedIn() && actionId.startsWith(request.auth.uid);
    }
  }
}
