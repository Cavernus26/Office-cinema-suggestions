rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // -------------------------------------------------------------------------
    // VALIDATORS
    // -------------------------------------------------------------------------
    function isValidRecommendation(data) {
      return data.keys().hasAll(['authorId', 'title', 'comment'])
        && data.authorId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.comment is string && data.comment.size() <= 2000;
    }

    function isNotAuthor(recId) {
      // Use the parent path variable if available, or fetch
      let rec = get(/databases/$(database)/documents/recommendations/$(recId));
      return rec != null && rec.data.authorId != request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        incoming().diff(existing()).affectedKeys().hasOnly(['avgRecommendationRating', 'totalRecommendationRatingSum', 'totalRecommendationRatingCount', 'recsCount', 'watchedCount', 'currentlyWatching'])
      );
      allow create: if isOwner(userId);
    }

    match /usernames/{name} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /recommendations/{recId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRecommendation(incoming());
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        existing().authorId == request.auth.uid || 
        incoming().diff(existing()).affectedKeys().hasOnly(['averageRating', 'ratingCount'])
      );

      match /ratings/{userId} {
        allow read: if isSignedIn();
        
        allow create, update: if isSignedIn() 
          && request.auth.uid == userId
          && incoming().rating is number
          && incoming().rating >= 1 
          && incoming().rating <= 5
          && isNotAuthor(recId);

        allow delete: if isOwner(userId);
      }
      
      match /actions/{actionId} {
        allow read: if isSignedIn();
        // actionId is the user's UID in this subcollection
        allow write: if isSignedIn() && (actionId == request.auth.uid || isOwner(resource.data.userId));
      }
    }

    match /userActions/{actionId} {
      allow read, write: if isSignedIn();
    }
  }
}
