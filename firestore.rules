rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isNameOwner(name) {
      let lowerName = name.toLower();
      let usernamePath = /databases/$(database)/documents/usernames/$(lowerName);
      return isSignedIn() && exists(usernamePath) && get(usernamePath).data.ownerId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /usernames/{name} {
      allow read, write: if isSignedIn();
      allow get: if true;
    }

    match /recommendations/{recId} {
      allow read, write: if isSignedIn();

      match /actions/{actionId} {
        allow read, write: if isSignedIn();
      }

      match /reactions/{reactionId} {
        allow read, write: if isSignedIn();
      }
    }

    match /userActions/{actionId} {
      allow read, write: if isSignedIn();
    }
  }
}
