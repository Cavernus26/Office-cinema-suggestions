rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        incoming().diff(existing()).affectedKeys().hasOnly([
          'avgRecommendationRating', 
          'totalRecommendationRatingSum', 
          'totalRecommendationRatingCount', 
          'recsCount', 
          'watchedCount', 
          'currentlyWatching'
        ])
      );
    }

    match /usernames/{name} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /recommendations/{recId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (existing().authorId == request.auth.uid);
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['averageRating', 'ratingCount', 'genres']);

      // Subcollections: Ratings and Actions
      match /ratings/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && userId == request.auth.uid;
      }
      
      match /actions/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && userId == request.auth.uid;
      }
    }

    match /userActions/{actionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        actionId.startsWith(request.auth.uid) || 
        incoming().userId == request.auth.uid
      );
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
