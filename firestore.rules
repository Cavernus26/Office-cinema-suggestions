rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isNameOwner(name) {
      let lowerName = name.toLower();
      let usernamePath = /databases/$(database)/documents/usernames/$(lowerName);
      return isSignedIn() && exists(usernamePath) && get(usernamePath).data.ownerId == request.auth.uid;
    }

    function isNameMatch(authorName) {
      return isNameOwner(authorName.toLower());
    }

    // -------------------------------------------------------------------------
    // VALIDATION
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      let requiredFields = ['name', 'avatar', 'watchedCount', 'recsCount', 'avgRating', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() > 0 &&
             data.avatar is string &&
             data.watchedCount is number &&
             data.recsCount is number &&
             data.avgRating is number;
    }

    function isValidRecommendation(data) {
      let required = ['tmdbId', 'title', 'type', 'authorId', 'authorName', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.tmdbId is number &&
             data.title is string &&
             data.type in ['movie', 'tv'] &&
             (data.authorId == request.auth.uid || isNameOwner(data.authorName));
    }

    function isValidUserAction(data) {
      return data.keys().hasAll(['userId', 'recommendationId', 'status', 'createdAt']) &&
             (data.userId == request.auth.uid || (data.keys().has('userName') && isNameOwner(data.userName))) &&
             data.status in ['Watching', 'Completed', 'Plan to Watch'];
    }

    function isValidReaction(data) {
      return data.keys().hasAll(['recommendationId', 'userId', 'emoji', 'createdAt']) &&
             data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if (isOwner(userId) || isNameOwner(incoming().name)) && isValidUser(incoming());
      allow delete: if isOwner(userId);
    }

    match /usernames/{name} {
      allow get: if true;
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || existing().passcode == incoming().passcode);
    }

    match /recommendations/{recId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRecommendation(incoming());
      allow update: if isSignedIn() && (
        (existing().authorId == request.auth.uid || isNameOwner(existing().authorName)) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['reactionsCount', 'averageRating', 'ratingCount'])
      );
      allow delete: if existing().authorId == request.auth.uid || isNameMatch(existing().authorName);

      match /actions/{actionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      match /reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn();
      }
    }

    match /userActions/{actionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
