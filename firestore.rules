rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isNameOwner(name) {
      let lowerName = name.toLower();
      let usernamePath = /databases/$(database)/documents/usernames/$(lowerName);
      return isSignedIn() && exists(usernamePath) && get(usernamePath).data.ownerId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['totalRecommendationRatingSum', 'totalRecommendationRatingCount', 'avgRecommendationRating', 'watchedCount', 'recsCount', 'currentlyWatching']));
      allow delete: if isOwner(userId);
    }

    match /usernames/{name} {
      allow get: if true;
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        existing().ownerId == request.auth.uid || 
        (incoming().passcode == existing().passcode && incoming().ownerId == request.auth.uid)
      );
    }

    match /recommendations/{recId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        existing().authorId == request.auth.uid || 
        incoming().diff(existing()).affectedKeys().hasOnly(['reactionsCount', 'averageRating', 'ratingCount'])
      );
      allow delete: if existing().authorId == request.auth.uid;

      match /actions/{actionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      match /reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn();
      }
    }

    match /userActions/{actionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
