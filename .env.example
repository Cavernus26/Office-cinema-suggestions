# Use this file as a template for your environment variables.
# For Vercel deployment, add these keys in the Vercel Dashboard (Settings -> Environment Variables).

# --- AI & Media Keys (Server-Side) ---
# DO NOT prefix these with VITE_ if you want them to remain server-side only.
GEMINI_API_KEY="your_gemini_api_key_here"
TMDB_API_KEY="your_tmdb_api_key_here"

# --- Firebase Configuration (Client-Side) ---
# IMPORTANT: This app uses CLOUD FIRESTORE, not Realtime Database.
# Ensure you have initialized "Cloud Firestore" in your Firebase Project!
# For React/Vite to see these, they MUST start with VITE_
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"
# IMPORTANT: Most projects use "(default)". 
# Only change this if you explicitly created a named database in Firebase Console.
VITE_FIREBASE_DATABASE_ID="(default)"

# --- Application URL ---
APP_URL="https://your-app-name.vercel.app"
