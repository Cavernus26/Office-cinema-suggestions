# Security Reminder: NEVER prefix sensitive API keys with VITE_ if they are used on the server.
# Only non-sensitive public configuration should be prefixed with VITE_ to expose to browser.

# GEMINI_API_KEY: Required for Gemini AI API calls. (Keep this secret!)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# TMDB_API_KEY: Required for movie/show search and metadata. (Keep this secret!)
# This is used on the server, so no VITE_ prefix here.
TMDB_API_KEY="YOUR_TMDB_API_KEY"

# Firebase Configuration (Required for Vercel Deployment)
# Get these values from your Firebase Project Settings
VITE_FIREBASE_API_KEY="YOUR_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_DATABASE_ID="(default)"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
